{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "Flame_Wand",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/flame_wand"
        }
      },
      {
        "when": "Calm_Wand",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/calm_wand"
        }
      },
      {
        "when": "Sparkle_Wand",
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/sparkle_wand"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/poisonous_potato"
    }
  }
}
